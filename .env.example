TZ=UTC

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_local_dev

# Airflow metadata database
AIRFLOW_UID=50000
AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_local_dev
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_FERNET_KEY=please_replace_with_a_real_32_byte_base64_key

# MLflow backend database
MLFLOW_DB=mlflow
MLFLOW_DB_USER=mlflow
MLFLOW_DB_PASSWORD=mlflow_local_dev

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Grafana
GRAFANA_ADMIN_PASSWORD=admin123

# Local service endpoints
SPARK_MASTER_URL=spark://spark-master:7077
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
MLFLOW_TRACKING_URI=http://mlflow:5000
MODEL_EXPORT_URI=s3://mlflow/serving/current/

# Conservative local Spark defaults for a 4 vCPU / 15 GiB VM
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=2g
SPARK_EXECUTOR_CORES=2
